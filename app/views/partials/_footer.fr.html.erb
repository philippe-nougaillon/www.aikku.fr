<div class:bg-info; overflow:hidden;">
  <svg viewBox="0 0 1200 60" preserveAspectRatio="none"
       style="display:block; width:100%; height:60px;">
    <path d="
      M0,60
      Q300,0 600,30
      Q900,60 1200,30
      L1200,60
      L0,60
      Z
    " fill="#1f1f3d"/>
  </svg>
</div>

<footer class="bg-info text-gray-200">

  <div class="grid grid-cols-1 md:grid-cols-2 p-2 md:px-8 md:pb-8 gap-6">


  <div class=" md:pl-10 flex flex-col justify-between items-center text-center">

      <div class="mb-6 mt-4 md:m-0">
        <p class="text-xs uppercase tracking-widest opacity-40 mb-4">
          Navigation
        </p>

        <%= link_to 'Accueil', root_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
        <%= link_to 'Nos services', services_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
        <%= link_to 'À propos', qui_sommes_nous_path, class: 'text-white block text-sm hover:text-secondary mb-2' %>
        <%= link_to 'Contact', contact_path, class: 'text-white block text-sm hover:text-secondary mb-1' %>

        <%= link_to 'https://www.linkedin.com/company/aikku-sas',
            target: '_blank',
            class: 'inline-flex items-center gap-2 rounded-lg text-sm hover:text-secondary' do %>
          LinkedIn <i class="fa-brands fa-linkedin"></i>
        <% end %>
      </div>

      <div class="flex flex-col gap-4 items-center text-white border-t mx-8 md:mx-0 border-white/10 p-4 ">

        Vous souhaitez en savoir plus ou nous demander une démo ?

           <%= link_to 'Contactez-nous →', contact_path, class:"btn btn-gradient shadow-sm shadow-white/40 w-44 h-10" %>
      </div>

    </div>
    
    <div class=" md:pl-10 my-4 md:m-0 md:border-l border-white/10 text-center">

      <span class="text-3xl font-black text-gradient">
        <%= @sitename %>
      </span>

      <p class="opacity-50 mt-4 text-base">
        AIKKU (La Défense)<br>
        5 Place de la Pyramide<br>
        92800 PUTEAUX
      </p>

      <hr class="my-3 mx-8 border-white/10 m">

      <p class="opacity-50 mt-4">
        AIKKU (Montfermeil)<br>
        112 Allée de Notre Dame des Anges<br>
        93370 MONTFERMEIL
      </p>

      <hr class="my-3 mx-8 border-white/10 m">

      <p class="opacity-50 mt-4">
        SAS au capital de 42.000 € <br> 
        SIREN : 934 780 735<br>
        R.C.S. Nanterre
      </p>

    </div>


    


  </div>

  <div class="flex flex-col md:flex-row justify-between px-6 md:px-8 pb-6 text-xs text-gray-200 gap-2">

    <span class="text-center md:text-right">
      Copyright © 2026 <%= @sitename %> — Tous droits réservés —
      <%= link_to 'Mentions Légales', mentions_legales_path, class: 'hover:underline' %>
    </span>

    <span class="text-center md:text-right">
      Made with ♥ by Aïkku
    </span>

  </div>

</footer>