<%= form_with(model: projet, class: "contents") do |form| %>
  <% if projet.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(projet.errors.count, "error") %> prohibited this projet from being saved:</h2>

      <ul>
        <% projet.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :nom %>
    <%= form.text_field :nom, class: "block shadow rounded-md border border-gray-200 outline-hidden px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= form.label :contenu %>
    <%= form.text_area :contenu, class: "block shadow rounded-md border border-gray-200 outline-hidden px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= form.label :url %>
    <%= form.text_field :url, class: "block shadow rounded-md border border-gray-200 outline-hidden px-3 py-2 mt-2 w-full" %>
  </div>

  <%= form.text_field :tag_list, value: projet.tag_list.join(', '), label: 'Tags' %>

  <div class="my-5">
    <%= form.label :poids %>
    <%= form.number_field :poids, class: "block shadow rounded-md border border-gray-200 outline-hidden px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="inline">
    <%= form.submit class: "rounded-lg py-3 px-5 bg-blue-600 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
