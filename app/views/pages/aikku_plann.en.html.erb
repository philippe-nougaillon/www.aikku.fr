<section class="text-center mb-16">
  <h1 class="font-black text-6xl text-accent mb-12 pt-8 italic">
    <%= title "Aikku PLANN" %>
  </h1>
  <h2 class="text-3xl lg:text-4xl mb-12 font-black !leading-10">
    <%= description "Manage all your training and rooms with
    <br> a simple, affordable and customizable solution".html_safe %>
  </h2>
  <h3 class="text-lg lg:text-2xl">
    Developed in collaboration with IAE Paris-Sorbonne, Aikku Plann is a job planning software of time and management room management.
    It is adapted to needs
    <span class="font-black">
      universities, business schools and specialized training institutes.
    </span>
  </h3>

  <div class="carousel min-w-16 sm:w-3/4 mx-auto mt-24 shadow-lg">
    <div id="slide1" class="carousel-item relative w-full">
      <%= image_tag "projets/planning iae-paris/screen_0.png", alt:"List of upcoming lessons" %>
    </div> 
    <div id="slide2" class="carousel-item relative w-full">
      <img src="/Images/guide/salles1.png" alt="Occupation of rooms (day)">
    </div> 
    <div id="slide3" class="carousel-item relative w-full">
      <img src="/Images/guide/salles2.png" alt="Occupation of rooms (week)">
    </div>
    <div id="slide4" class="carousel-item relative w-full">
      <img src="/Images/guide/cours3.png" alt="Occupation rooms in detail (week)">
    </div>
    <div id="slide5" class="carousel-item relative w-full">
      <img src="/Images/guide/afficheur.png" alt="Planning on display 1/2">
    </div>
    <div id="slide6" class="carousel-item relative w-full">
      <img src="/Images/guide/cours_new.png" alt="Room reservation form">
    </div>
    <div id="slide7" class="carousel-item relative w-full">
      <img src="/Images/guide/reservation-saison.png" alt="Reservation of time slots for a season">
    </div>
    <div id="slide8" class="carousel-item relative w-full">
      <img src="/Images/guide/formation.png" alt="A formation in detail">
    </div>
    <div id="slide9" class="carousel-item relative w-full">
      <img src="/Images/guide/intervenant.png" alt="A detailed speaker">
    </div>
    <div id="slide10" class="carousel-item relative w-full">
      <img src="/Images/guide/a_booker.png" alt="List of lessons 'in Booker'">
    </div>
    <div id="slide11" class="carousel-item relative w-full">
      <img src="/Images/guide/invits.png" alt="List of invitations (proposals for time slots)">
    </div>
    <div id="slide12" class="carousel-item relative w-full">
      <img src="/Images/guide/outils.png" alt="List of tools">
    </div>
  </div>
  <div data-controller="carousel-paginate">
    <div class="flex flex-wrap justify-center w-full gap-2 mt-4">
      <a href="#slide1" class="btn btn-accent hover:btn-accent btn-xs carousel-page" data-action="click->carousel-paginate#activate">1</a> 
      <a href="#slide2" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">2</a> 
      <a href="#slide3" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">3</a> 
      <a href="#slide4" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">4</a> 
      <a href="#slide5" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">5</a> 
      <a href="#slide6" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">6</a> 
      <a href="#slide7" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">7</a> 
      <a href="#slide8" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">8</a> 
      <a href="#slide9" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">9</a> 
      <a href="#slide10" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">10</a> 
      <a href="#slide11" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">11</a> 
      <a href="#slide12" class="btn btn-primary btn-outline btn-xs carousel-page hover:btn-accent" data-action="click->carousel-paginate#activate">12</a>
    </div>
  </div>

  <div class="hidden lg:flex flex-wrap justify-center gap-4 mt-24">
    <%= link_to "You are training manager", aikku_plann_path(anchor: "bref"), class: 'btn btn-accent sm:btn-lg max-w-full' %>
    <%= link_to "You are an administrator", aikku_plann_path(anchor: "details_fonctionnalites"), class: 'btn btn-secondary sm:btn-lg max-w-full' %>
  </div>
</section>

<section id="bref" class="w-full text-center bg-secondary text-secondary-content py-24">
  <h2 class="apps-title">
    A powerful tool. Features to gain efficiency
  </h2>
  <div class="flex flex-wrap justify-around gap-16 mt-12">
    <div class="flex flex-col flex-1">
      <p class="text-2xl font-black mb-6">
        Quickly plan the lessons
      </p>
      <p>
        Choose the training, the speaker (s) and the classroom (from the available rooms available automatically): your course is created in a few clicks and integrated into the schedule.
      </p>
    </div>
    <div class="flex flex-col flex-1">
      <p class="text-2xl font-black mb-6">
        Manage the occupation of your rooms
      </p>
      <p>
        Visualize all the slots available in your establishment.Manage the occupancy rate of the classrooms, at a glance.
      </p>
    </div>
    <div class="flex flex-col flex-1">
      <p class="text-2xl font-black mb-6">
        Communicate easily
      </p>
      <p>
        Notify students and stakeholders, by email or SMS, in the event of modification or cancellation of a course.
      </p>
    </div>
  </div>
</section>

<section id="responsive" class="flex flex-col md:flex-row flex-wrap items-center gap-16 mt-24">
  <div class="flex-1 card w-full sm:w-full">
    <%= image_tag "misc/planning-responsive.png", class:"shadow rounded-2xl" %>
  </div>
  <div class="flex-1">
    <p class="text-2xl text-secondary font-light">
      Information always available
    </p>
    <p class="text-4xl font-black my-4">
      An accessible schedule everywhere,
      <br>on all supports
    </p>
    <p class="text-xl">
      The application is optimized to display on all screen sizes.
      <br><br>Distribute the schedule of the day on the light panels of your establishment: the progress of the courses is updated in real time, for clearer and readable information.
      <br><br>Your students and stakeholders can consult the planning on phones, computers or tablets, 24 hours a day and 7 days a week.
      A flow. ICS allows them to synchronize it with the agenda application of their choice.
    </p>
    <div class="flex gap-8 mt-12">
      <%= image_tag "logos/Gmail.svg", width: "50px" %>
      <%= image_tag "logos/Outlook.svg", width: "50px" %>
      <%= image_tag "logos/MacOSCalendar.webp", width: "50px" %>
      <%= image_tag "logos/GoogleCalendar.svg", width: "50px" %>

    </div>
  </div>
</section>

<section id="fonctionnalités" class="w-full text-center bg-secondary text-secondary-content mt-24 pt-24">
  <h2 class="apps-title">Complete software, adapted to each role in your establishment</h2>
  <div class="flex flex-col w-full gap-16 mt-24">
    <div class="flex-1 flex flex-col md:flex-row flex-wrap justify-around gap-16">
      <div class="flex flex-col flex-1">
        <i class="fa-regular fa-calendar-days fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4"><b>Course schedule</b></p>
        <p class="!font-thin">
          Create or change a course: the software automatically searchs for an available room.Save time with advanced research.Make mass modifications for a set of courses, in a few clicks.
        </p>
      </div>
      <div class="flex flex-col flex-1">
        <i class="fa-solid fa-chalkboard fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4">Course rooms</p>
        <p>
          Visualize free time slots, per day, week and room.Manage the capacity of your rooms and your establishment.You are alerted when the maximum capacity per room is reached.
        </p>
      </div>
      <div class="flex flex-col flex-1">
      <i class="fa-solid fa-briefcase fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4">Formations</p>
        <p>
          Locate each training in the schedule thanks to its color code.Access the list of stakeholders.More easily pilot the hourly volume of the EU: hours carried out, planned lessons and remaining to be created.
        </p>
      </div>
    </div>
    <div class="flex-1 flex flex-col md:flex-row flex-wrap justify-around gap-16 lg:gap-8">
      <div class="flex flex-col flex-1">
        <i class="fa-solid fa-chalkboard-teacher fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4">Speakers</p>
        <p>
          Centralize all the information for each speaker.Visualize their service states according to their status.Value the effective course time for temporary workers for facilitated invoicing.
        </p>
      </div>
      <div class="flex flex-col flex-1">
        <i class="fa-solid fa-graduation-cap fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4">Students</p>
        <p>
          Access the list of students in training and inform them by email or SMS in the event of a change in their schedule.
        </p>
      </div>
      <div class="flex flex-col flex-1">
        <i class="fa-solid fa-download fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4">Import and export of data</p>
        <p>
          Import large volumes of data in Excel (XLS) and CSV formats: courses, training, students, etc. All data can be exported to XLS format.
        </p>
      </div>
    </div>
    
    <div class="flex-1 flex flex-col md:flex-row flex-wrap justify-around gap-16 lg:gap-8">
      <div class="flex flex-col flex-1">
        <i class="fa-solid fa-file-signature fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4">Emargements</p>
        <p>
          Simplify the management of student presence presence by digitizing signatures, which signs directly on your smartphone or PC at the start of each session.
        </p>
      </div>
      <div class="flex flex-col flex-1">
        <i class="fa-solid fa-robot fa-2xl mb-4"></i>
        <p class="text-2xl font-black my-4">GPT-4</p>
        <p>
          Ask the planning databases by simple questions asked in natural language, as "how many hours of courses the speaker Durand will have next week?".
        </p>
      </div>
      <div class="flex flex-col flex-1">
        <p class="text-2xl font-black my-4"></p>
        <p>
        </p>
      </div>
    </div>
  </div>
  <div class="mt-8">
    <p class="text-2xl text-center mt-24 mb-12">
      Do you want to discover all the features?
      <%= link_to "Contact us", aikku_plann_path(anchor: "contact"), class: 'link' %>.
      <br>
      Need tailor-made feature? We develop it!
    </p>
  </div>
</section>

