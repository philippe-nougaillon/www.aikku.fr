<section id="details_fonctionnalites" class="bg-info text-white mx-auto w-full text-center pt-24">
    
 <h2 class="text-3xl lg:text-5xl text-center font-black mb-12">
  Fonctionnalités avancées <span class="text-gradient"> d'administration</span></h2>
  <h2 class="text-center text-accent font-bold text-xl">POUR LES ADMINISTRATEURS</h2>



  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mx-8 my-16 md:mt-16">
    
      <div class="flex flex-col p-6 bg-white  rounded-xl">
       <h3 class="text-2xl font-black my-4 text-center text-accent  ">
        <i class="fa-solid fa-triangle-exclamation fa-lg mr-2"></i>
         Prévention des anomalies</h3>
         <p class="text-justify text-gray-600">
         Un algorithme de vérification des contraintes 
         (capacité, disponibilité, jours de fermeture) 
         prévient les erreurs de planification. Un pictogramme 
         alerte l'utilisateur en cas d'anomalie de saisie.
        </p>
      </div>

      <div class="flex flex-col p-6 bg-white  rounded-xl">
       <h3 class="text-2xl font-black my-4 text-center text-accent  ">
        <i class="fa-solid fa-calendar-check fa-lg mr-2"></i>
        Plans d'activité</h3>
         <p class="text-justify text-gray-600">
          Réservez des créneaux pour chaque formation en masse sur 
          toute une année universitaire avec la fonctionnalité Nouvelle
          Saison.
        </p>
      </div>

      <div class="flex flex-col p-6 bg-white  rounded-xl">
       <h3 class="text-2xl font-black my-4 text-center text-accent  ">
        <i class="fa-solid fa-gears fa-lg mr-2"></i>
        Flux de travail intelligents</h3>
         <p class="text-justify text-gray-600">
          Centralisez et automatisez la gestion des dossiers de 
          candidature des nouveaux intervenants et le processus de 
          propositions de créneaux horaires.
        </p>
      </div>

      <div class="flex flex-col p-6 bg-white  rounded-xl">
       <h3 class="text-2xl font-black my-4 text-center text-accent  ">
        <i class="fa-solid fa-tools fa-lg mr-2"></i>
        Outils d'administration</h3>
         <p class="text-justify text-gray-600">
          Gérez les accès utilisateurs avec sept rôles possibles. 
          Configurez les créneaux par bâtiment et les jours de fermeture.</p>
      </div>

      <div class="flex flex-col p-6 bg-white  rounded-xl">
       <h3 class="text-2xl font-black my-4 text-center text-accent  ">
        <i class="fa-solid fa-search fa-lg mr-2"></i>
        Journal d'audit</h3>
         <p class="text-justify text-gray-600">
          Retracez toutes les modifications effectuées par chaque utilisateur 
          dans les données de l'application, grâce à l'historique des 
          modifications (Audit Trail).
        </p>
      </div>

      <div class="flex flex-col p-6 bg-white  rounded-xl">
       <h3 class="text-2xl font-black my-4 text-center text-accent  ">
        <i class="fa-solid fa-envelope-open fa-lg mr-2"></i>
        Journal des e-mails</h3>
         <p class="text-justify text-gray-600">
          Accédez à l'historique des envois de notification aux étudiants et aux intervenants.
          Identifiez les adresses incorrectes et les notifications non lues.</p>
      </div>

  </div>

  
</section> 
